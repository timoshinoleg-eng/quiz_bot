# ============================================
# MAX-Квиз Bot Configuration
# ============================================

# Bot Token (получить у @BotFather в Telegram или от MAX API)
BOT_TOKEN=your_bot_token_here

# Environment (development, staging, production)
ENV=development
DEBUG=true

# ============================================
# Database Configuration
# ============================================

# PostgreSQL (для production)
POSTGRES_USER=quiz_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=quiz_db
POSTGRES_PORT=5432

# Полный URL для SQLAlchemy
DATABASE_URL=postgresql+asyncpg://quiz_user:your_secure_password_here@localhost:5432/quiz_db

# Для разработки можно использовать SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./quiz_bot.db

# Connection Pool Settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ============================================
# Redis Configuration
# ============================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# Webhook Configuration (для production)
# ============================================

WEBHOOK_URL=https://your-domain.com
WEBHOOK_PATH=/webhook
POLLING_TIMEOUT=30

# ============================================
# Game Settings
# ============================================

# Время на ответ (секунды)
ANSWER_TIMEOUT=30

# Максимальное количество жизней
MAX_LIVES=3

# Частота показа рекламы (каждые N вопросов)
AD_FREQUENCY=3

# ============================================
# Premium Subscription (YooKassa)
# ============================================

# Получить на https://yookassa.ru/
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key

# Цены
PREMIUM_PRICE_RUB=349
PREMIUM_PRICE_USD=3.99

# ============================================
# Feature Flags
# ============================================

ENABLE_ADS=true
ENABLE_PREMIUM=true
ENABLE_DUELS=true
ENABLE_TOURNAMENTS=false
ENABLE_STREAKS=true
ENABLE_ANALYTICS=true

# ============================================
# Rate Limiting
# ============================================

RATE_LIMIT_IP=100
RATE_LIMIT_USER=30

# ============================================
# Analytics
# ============================================

# Токен для сервиса аналитики (опционально)
ANALYTICS_TOKEN=

# ============================================
# Nginx Ports
# ============================================

NGINX_PORT=80
NGINX_SSL_PORT=443
